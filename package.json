{
  "name": "ultimate-powerflow-card",
  "version": "1.0.0",
  "description": "A polished Home Assistant Lovelace card that visualizes energy flow over a house image with animated neon power flows.",
  "main": "dist/ultimate-powerflow-card.js",
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "watch": "rollup -c rollup.config.js --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "custom-card",
    "hacs",
    "energy",
    "powerflow",
    "solar",
    "battery",
    "ev-charger"
  ],
  "author": "Ultimate Powerflow Card Contributors",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "rollup": "^4.12.0",
    "rollup-plugin-terser": "^7.0.2",
    "tslib": "^2.6.2",
    "typescript": "^5.4.2"
  },
  "dependencies": {
    "lit": "^3.1.2"
  }
}
